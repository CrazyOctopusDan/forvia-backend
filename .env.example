# Default local mode
NODE_ENV=development
PORT=3000
DB_MODE=mock

# Alarm engine debounce
ALARM_DEBOUNCE_N=2
ALARM_RECOVER_M=2
SSE_HEARTBEAT_MS=20000

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# SQL Server (used when DB_MODE=sqlserver)
DB_HOST=127.0.0.1
DB_PORT=1433
DB_NAME=forvia_factory
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd
